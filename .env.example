# =====================================================================
# Variáveis de ambiente — Corrida das Famílias
# Copie para `.env` (não commit) e preencha os valores reais.
# =====================================================================

# --- Servidor (Hostinger Web App Node.js / runtime) -------------------
NODE_ENV=production
PORT=3000

# URL pública canônica do site (sem barra no final).
# Usada no servidor para montar redirect_url da InfinitePay.
PUBLIC_SITE_URL=https://www.corridadasfamilias.com.br

# --- Cliente (Vite, expostas no bundle do browser) --------------------
VITE_PUBLIC_SITE_URL=https://www.corridadasfamilias.com.br
VITE_SUPABASE_URL=https://ljquyrrprrwqpmaomwsh.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=ljquyrrprrwqpmaomwsh

# --- Supabase (server-side / admin) -----------------------------------
# IMPORTANTE: SUPABASE_SERVICE_ROLE_KEY bypassa RLS. Nunca expor no frontend.
SUPABASE_URL=https://ljquyrrprrwqpmaomwsh.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Lovable AI Gateway (opcional) ------------------------------------
LOVABLE_API_KEY=
